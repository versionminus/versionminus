# FastAPI service settings
MODELHUB_API_KEY=paste
MODELHUB_BASE_URL=paste
MODELHUB=paste
# Application direct URL override (async driver form). Leave commented to let settings build it.
# Chunking / RAG detection
# Auth0 / OIDC configuration (required when AUTH_ENABLED=true)
AUTH_ENABLED=true
AUTH_TESTING_MODE=false
AUTH_DOMAIN=paste
AUTH_SPA_APPLICATION_CLIENT_NAME=paste
AUTH_SPA_APPLICATION_CLIENT_ID=paste
AUTH_SPA_APPLICATION_CLIENT_SECRET=paste
AUTH_NATIVE_APPLICATION_CLIENT_NAME=paste
AUTH_NATIVE_APPLICATION_CLIENT_ID=paste
AUTH_NATIVE_APPLICATION_CLIENT_SECRET=paste
AUTH_API_AUDIENCE=paste
AUTH_API_NAME=paste

# Web client (Vite) Auth0 configuration
VITE_AUTH0_DOMAIN=paste
VITE_AUTH0_CLIENT_ID=paste
VITE_AUTH0_AUDIENCE=paste
VITE_AUTH0_REDIRECT_URI=http://localhost
VITE_AUTH0_SCOPE="openid profile email offline_access"
VITE_API_BASE=/api
# tmp (openai)
VECTOR_STORE_ID="paste"
VECTOR_STORE_NAME="paste"
OPENAI_API_KEY="paste"
