COMPOSE_PROJECT_NAME=licodex

# Postgres defaults (used by compose and settings parsing)
POSTGRES_USER=licodex
POSTGRES_PASSWORD=licodexpwd
POSTGRES_DB=licodex
POSTGRES_HOST=db
POSTGRES_PORT=5432
ENV=dev

# FastAPI service settings
APP_NAME=licodex-api
LOG_LEVEL=INFO
API_PREFIX=/api/v1
ENABLE_CORS=true
MODELHUB_API_KEY=paste
MODELHUB_BASE_URL=paste
MODELHUB=paste
# Application direct URL override (async driver form). Leave commented to let settings build it.
DATABASE_URL=postgresql+asyncpg://licodex:licodexpwd@db:5432/licodex
# Chunking / RAG detection
CHUNK_BOUNDARY_POLICY_DEFAULT=paragraph_sentence
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=50
CHUNK_POLICY_DETECTION_ENABLED=false
CHUNK_POLICY_MODEL_PATH=/models/mistral-7b-instruct-q4_k_m.gguf
CHUNK_POLICY_MODEL_CTX=2048
CHUNK_POLICY_MODEL_THREADS=16
CHUNK_POLICY_MCP_ENABLED=false
CHUNK_POLICY_MCP_HOST=licodex-mcp
CHUNK_POLICY_MCP_PORT=8080
CHUNK_POLICY_MCP_USE_TLS=false
# OIDC
AUTH_APPLICATION_NAME="licodex"
AUTH_APPLICATION_CLIENT_ID="paste"
AUTH_APPLICATION_CLIENT_SECRET="paste"
AUTH_AUTHORISATION_SERVER="paste"
